{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "setupFiles": ["<rootDir>/jest-e2e.env.ts"],
  "globalSetup": "<rootDir>/jest-e2e.global-setup.ts",
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/../src/$1",
    "^generated/prisma/client$": "<rootDir>/../generated/prisma/client",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "tsconfig": {
          "isolatedModules": true
        },
        "diagnostics": {
          "ignoreCodes": [151002]
        }
      }
    ]
  }
}